# Auto-generated by ComfyUI-4K4D — Experiment Configuration
# Dataset: {{ dataset_name }}
# Experiment: {{ experiment_name }}
# NOTE: No 'configs:' parent reference — the base architecture config
# (e.g. configs/exps/4k4d/4k4d_0013_01.yaml) is chained via the -c flag.

exp_name: {{ experiment_name }}

dataloader_cfg:
    dataset_cfg:
        data_root: {{ data_root }}
        view_sample: [{{ view_sample }}]
        frame_sample: [{{ frame_sample }}]

val_dataloader_cfg:
    dataset_cfg:
        data_root: {{ data_root }}
        focal_ratio: {{ focal_ratio | default(0.5) }}

{% if training_mode == 'preview_static' %}
# Preview static mode — single frame, fast validation
runner_cfg:
    epochs: 1
    ep_iter: {{ max_iterations | default(200) }}
    save_ep: 1
    save_latest_ep: 1
    eval_ep: 1
{% else %}
# Full sequence mode — all frames, production quality
runner_cfg:
    epochs: 1
    ep_iter: {{ max_iterations | default(1600) }}
    save_ep: 1
    save_latest_ep: 1
    eval_ep: 1
{% endif %}

model_cfg:
    sampler_cfg:
        bg_brightness: {{ bg_brightness | default(0.0) }}
